{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore --staged:*)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git log:*)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false
}
